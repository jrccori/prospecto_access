# URL pública de la Edge Function de validación (SÍ puede ir en el cliente).
# Reemplaza <PROJECT_REF> por la referencia de tu proyecto Supabase.
NEXT_PUBLIC_VALIDAR_ENDPOINT=https://<PROJECT_REF>.supabase.co/functions/v1/validar-postulante

# ---------------------------------------------------------------------------
# NUNCA pongas SUPABASE_SERVICE_ROLE_KEY en el frontend ni con prefijo
# NEXT_PUBLIC_. Ese secreto vive SOLO en la Edge Function:
#   supabase secrets set FRONTEND_ORIGIN=https://tu-dominio.com
# (SUPABASE_URL y SUPABASE_SERVICE_ROLE_KEY se inyectan automáticamente en la
#  Edge Function; no necesitas definirlos manualmente.)
# ---------------------------------------------------------------------------
